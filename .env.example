# AI CLI Bridge (Clink-Only) Environment Configuration
# Copy this file to .env and adjust as needed.

# -----------------------------------------------------------------------------
# Clink runtime
# -----------------------------------------------------------------------------

# Optional: Override CLI client config source (file or directory).
# Defaults to built-in conf/cli_clients plus ~/.pal/cli_clients.
# CLI_CLIENTS_CONFIG_PATH=/absolute/path/to/cli_clients

# Optional: MCP transport output budget (tokens).
# Some MCP clients set this automatically; leave unset unless you need to override.
# MAX_MCP_OUTPUT_TOKENS=25000

# -----------------------------------------------------------------------------
# Conversation and response behavior
# -----------------------------------------------------------------------------

# Optional: Default model label used for metadata/routing hints in responses.
# In clink-only mode this does not configure server-side model providers.
DEFAULT_MODEL=auto

# Optional: Language/locale preference for tool responses.
# Examples: en-US, zh-CN, ja-JP
# LOCALE=en-US

# Optional: Conversation timeout in hours for in-memory thread state.
CONVERSATION_TIMEOUT_HOURS=24

# Optional: Maximum turns per conversation thread.
MAX_CONVERSATION_TURNS=40

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=DEBUG

# -----------------------------------------------------------------------------
# Environment precedence
# -----------------------------------------------------------------------------

# Force .env values to override system environment variables.
# true  = prefer values in .env
# false = use normal system precedence
PAL_MCP_FORCE_ENV_OVERRIDE=false

# -----------------------------------------------------------------------------
# Docker/local runtime helpers
# -----------------------------------------------------------------------------

# Docker Compose project name
COMPOSE_PROJECT_NAME=pal-mcp

# Timezone for containerized environments
TZ=UTC

# Maximum log file size when file-based logging is enabled
LOG_MAX_SIZE=10MB

# -----------------------------------------------------------------------------
# Notes
# -----------------------------------------------------------------------------

# This clink-only server does not require provider API keys in .env.
# Configure authentication in each external CLI client instead
# (for example codex/claude/gemini CLI native login or env setup).
