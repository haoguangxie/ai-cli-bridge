{
  "name": "claude",
  "command": "claude",
  "additional_args": [
    "--permission-mode",
    "bypassPermissions",
    "--model",
    "opus"
  ],
  "env": {},
  "timeout_seconds": 10800,
  "roles": {
    "default": {
      "prompt_path": "systemprompts/clink/default.txt",
      "role_args": []
    },
    "planner": {
      "prompt_path": "systemprompts/clink/default_planner.txt",
      "role_args": []
    },
    "codereviewer": {
      "prompt_path": "systemprompts/clink/default_codereviewer.txt",
      "role_args": []
    }
  }
}
